{
    "name": "Email Writer assistant ",
    "description": "AI powered email writing reply assistant",
    "version": "1.0",
    "manifest_version": 3,
    "icons": {
        "16": "icon/SmartEmail16.png",
        "48": "icon/SmartEmail48.png",
        "128": "icon/SmartEmail128.png"
    },
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "http://localhost:8089/*",
        "*://mail.google.com/*"
    ],
    "action": {
        "default_title": "Email Writer assistant ",
        "default_icon": {
            "16": "icon/SmartEmail16.png",
            "48": "icon/SmartEmail48.png",
            "128": "icon/SmartEmail128.png"
        }
    },
    "content_scripts": [
        {
            "js": [
                "content.js"
            ],
            "matches": [
                "*://mail.google.com/*"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icon/*"
            ],
            "matches": [
                "*://mail.google.com/*"
            ]
        }
    ]
}